# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local

# vercel
.vercel

# superpowers
.superpowers/
docs/superpowers/

# temp/scratch files (root only)
/_append.py
/_gen.py
/_write_adv.js
/test_heredoc.txt
/invoice_docx_tmp/
/*.code-workspace
/*.mmd
/*.png
/*.docx
/*.doc

# playwright snapshots
*-snapshot.yml
*-screenshot.png

# sqlite
prisma/dev.db

# playwright mcp
.playwright-mcp/

# typescript
*.tsbuildinfo
next-env.d.ts

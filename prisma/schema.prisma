  deliveryMethod  DeliveryMethod @map("delivery_method")
  recipientEmail  String?       @map("recipient_email")
  status          DeliveryStatus @default(PENDING)
  deliveredAt     DateTime?     @map("delivered_at")
  downloadCount   Int           @default(0) @map("download_count")
  printCount      Int           @default(0) @map("print_count")
  errorMessage    String?       @map("error_message")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("invoice_delivery_records")
}

model InvoiceVerifyRecord {
  id              String       @id @default(cuid())
  invoiceId       String       @map("invoice_id")
  invoice         OutputInvoice @relation(fields: [invoiceId], references: [id])
  inputInvoiceId  String?      @map("input_invoice_id")

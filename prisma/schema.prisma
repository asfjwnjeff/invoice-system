  verifyStatus    VerifyStatus @map("verify_status")
  verifyResult    Json?        @map("verify_result")
  verifiedAt      DateTime?    @map("verified_at")
  errorMessage    String?      @map("error_message")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("invoice_verify_records")
}

model ArchiveRecord {
  id            String        @id @default(cuid())
  archiveNo     String        @unique @map("archive_no")
  entityType    String        @map("entity_type")
  entityId      String        @map("entity_id")
  archiveStatus ArchiveStatus @default(PENDING_ARCHIVE) @map("archive_status")

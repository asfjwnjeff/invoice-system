model RedFlushApplication {
  id                  String          @id @default(cuid())
  applicationNo       String          @unique @map("application_no")
  originalInvoiceId   String          @map("original_invoice_id")
  originalInvoice     OutputInvoice   @relation(fields: [originalInvoiceId], references: [id])
  redFlushType        RedFlushType    @map("red_flush_type")
  redFlushReason      RedFlushReason  @map("red_flush_reason")
  reasonDescription   String          @map("reason_description")
  amountWithoutTax    Decimal         @default(0) @map("amount_without_tax")
  taxAmount           Decimal         @default(0) @map("tax_amount")
  amountWithTax       Decimal         @default(0) @map("amount_with_tax")
  needsReissue        Boolean         @default(false) @map("needs_reissue")
  status              RedFlushStatus  @default(DRAFT)
  approvedBy          String?         @map("approved_by")
  confirmationFormId  String?         @unique @map("confirmation_form_id")
  confirmationForm    RedConfirmationForm? @relation("RedFlushConfirmationForm", fields: [confirmationFormId], references: [id])
  redInvoiceNo        String?         @map("red_invoice_no")
  reissueDraftId      String?         @map("reissue_draft_id")
  attachments         Json            @default("[]")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  items RedFlushItem[]

  @@map("red_flush_applications")
}

model RedFlushItem {
  id              String              @id @default(cuid())
  applicationId   String              @map("application_id")
  application     RedFlushApplication @relation(fields: [applicationId], references: [id])
  itemName        String              @map("item_name")
  originalItemId  String?             @map("original_item_id")
  amount          Decimal             @default(0)
  taxRate         Decimal             @default(0) @map("tax_rate")
  taxAmount       Decimal             @default(0) @map("tax_amount")
  totalAmount     Decimal             @default(0) @map("total_amount")
  sortOrder       Int                 @default(0) @map("sort_order")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@map("red_flush_items")
}

model RedConfirmationForm {
  id                      String              @id @default(cuid())
  formNo                  String              @unique @map("form_no")
  application             RedFlushApplication? @relation("RedFlushConfirmationForm")
  status                  RedFlushStatus      @default(PENDING_CONFIRM_FORM)
  counterpartConfirmed    Boolean             @default(false) @map("counterpart_confirmed")
  counterpartConfirmedAt  DateTime?           @map("counterpart_confirmed_at")
  expiredAt               DateTime?           @map("expired_at")
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  @@map("red_confirmation_forms")
}

model VoidApplication {
  id              String       @id @default(cuid())
  applicationNo   String       @unique @map("application_no")
  invoiceId       String?      @map("invoice_id")
  invoice         OutputInvoice? @relation(fields: [invoiceId], references: [id])
  voidCategory    VoidCategory @map("void_category")
  voidReason      VoidReason   @map("void_reason")
  reasonDetail    String?      @map("reason_detail")
  status          VoidStatus   @default(DRAFT)
  approvedBy      String?      @map("approved_by")
  executedAt      DateTime?    @map("executed_at")
  attachments     Json         @default("[]")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("void_applications")
}

model InvoiceFile {
  id          String   @id @default(cuid())
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  fileType    String   @map("file_type")
  fileSize    Int      @map("file_size")
  mimeType    String?  @map("mime_type")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  outputInvoiceId String? @map("output_invoice_id")
  outputInvoice OutputInvoice? @relation(fields: [outputInvoiceId], references: [id])
  inputInvoiceId  String? @map("input_invoice_id")
  inputInvoice  InputInvoice? @relation(fields: [inputInvoiceId], references: [id])
  uploadedBy  String?  @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("invoice_files")
}

model InvoiceDeliveryRecord {
  id              String        @id @default(cuid())
  invoiceId       String        @map("invoice_id")

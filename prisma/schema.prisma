generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────

enum InvoiceDirection {
  OUTPUT
  INPUT
}

enum BlueRedFlag {
  BLUE
  RED
}

enum InvoiceCategory {
  DIGITAL_SPECIAL
  DIGITAL_NORMAL
  VAT_SPECIAL
  VAT_NORMAL
  E_NORMAL
  CUSTOMS_IMPORT_VAT_PAYMENT
  CUSTOMS_DUTY_PAYMENT
  TRANSPORT_INVOICE
  WAREHOUSE_INVOICE
  ADVANCE_PAYMENT_NOTICE
  RED_INVOICE
}

enum FeeType {
  CUSTOMS_SERVICE
  WAREHOUSE_SERVICE
  TRANSPORT_SERVICE
  AGENCY_SERVICE
  CUSTOMS_DUTY
  IMPORT_VAT
  INSPECTION_FEE
  PORT_FEE
  INSURANCE
  COURIER_FEE
  OTHER_ADVANCE
}

enum AdvanceStatus {
  DRAFT
  PENDING_CONFIRM
  CONFIRMED
  PENDING_COLLECTION
  PARTIALLY_COLLECTED
  COLLECTED
  WRITTEN_OFF
  CANCELLED
  DISPUTED
}

enum AppStatus {
  DRAFT
  READY
  PENDING_APPROVAL
  REJECTED
  PENDING_ISSUE
  ISSUING
  ISSUED
  ISSUE_FAILED
  DELIVERED
  RED_FLUSHED
  PARTIALLY_RED_FLUSHED
  VOIDED
  CANCELLED
}

enum RedFlushStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  PENDING_CONFIRM_FORM
  WAITING_COUNTERPART_CONFIRM
  CONFIRMED
  CONFIRM_FORM_EXPIRED
  RED_ISSUING
  RED_ISSUED
  RED_FAILED
  COMPLETED
  CANCELLED
}

enum VoidStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXECUTED
  CANCELLED
}

enum VerifyStatus {
  PENDING
  VERIFIED
  VERIFY_FAILED
  NOT_FOUND
  AMOUNT_MISMATCH
  SELLER_ABNORMAL
  VOIDED
  RED_FLUSHED
  TIMEOUT
}

enum DeductStatus {
  PENDING
  DEDUCTED
  NON_DEDUCT
  DEDUCT_FAILED
}

enum AccountStatus {
  UNACCOUNTED
  ACCOUNTED
}

enum ArchiveStatus {
  UNARCHIVED
  PENDING_ARCHIVE
  ARCHIVED
  SUPPLEMENTED
}

enum DeliveryStatus {
  PENDING
  DELIVERING
  DELIVERED
  FAILED
  DOWNLOADED
  PRINTED
  REDELIVERED
}

enum PayerType {
  COMPANY
  CUSTOMER
  THIRD_PARTY
}

enum InvoiceStrategy {
  NO_INVOICE
  SEPARATE_INVOICE
  MERGE_WITH_SERVICE
  SERVICE_ONLY
  NET_AMOUNT_INVOICE
  MANUAL
}

enum AdvanceCollectionStatus {
  PENDING
  PARTIALLY_COLLECTED
  COLLECTED
}

enum WriteOffStatus {
  PENDING
  WRITTEN_OFF
}

enum SettlementStatus {
  DRAFT
  PENDING_BIZ_CONFIRM
  PENDING_FIN_CONFIRM
  PENDING_CUSTOMER_CONFIRM
  CONFIRMED
  PARTIALLY_INVOICED
  INVOICED
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum OrderStatus {
  DRAFT
  ACTIVE
  IN_PROGRESS
  COMPLETED
  CLOSED
  CANCELLED
}

enum Currency {
  CNY
  USD
  EUR
  HKD
  JPY
  KRW
  TWD
}

enum RedFlushType {
  FULL
  PARTIAL
  REISSUE
  DISCOUNT
  SERVICE_TERMINATION
  RETURN
}

enum RedFlushReason {
  SALES_RETURN
  SERVICE_TERMINATION
  INVOICE_ERROR
  AMOUNT_DISCOUNT
  OTHER
}

enum VoidReason {
  BUYER_INFO_ERROR
  TAX_NO_ERROR
  AMOUNT_ERROR
  TAX_RATE_ERROR
  ITEM_ERROR
  DUPLICATE_ISSUE
  CUSTOMER_CANCELLED
  BUSINESS_CANCELLED
  OTHER
}

enum VoidCategory {
  APPLICATION_CANCEL
  LEGACY_INVOICE_VOID
  AGENCY_INVOICE_VOID
}

enum SourceType {
  MANUAL
  SETTLEMENT
  BUSINESS_ORDER
  ADVANCE_PAYMENT
  IMPORT
  API
}

enum DeliveryMethod {
  EMAIL
  QR_CODE
  DOWNLOAD
  API_PUSH
  CUSTOMER_PORTAL
}

enum SettlementType {
  CUSTOMER_RECEIVABLE
  SUPPLIER_PAYABLE
  ADVANCE_SETTLEMENT
  COMPREHENSIVE
}

enum InputInvoiceStatus {
  PENDING_PARSE
  PARSED
  PENDING_VERIFY
  VERIFIED
  VERIFY_FAILED
  PENDING_MATCH
  MATCHED
  PENDING_DEDUCT
  DEDUCTED
  NON_DEDUCT
  ACCOUNTED
  ARCHIVED
  RED_FLUSHED
  ABNORMAL
}

enum CustomsPaymentBookType {
  IMPORT_VAT_PAYMENT
  CUSTOMS_DUTY_PAYMENT
  OTHER_TAX
}

enum CustomsTaxType {
  CUSTOMS_DUTY
  IMPORT_VAT
  CONSUMPTION_TAX
  OTHER
}

// ─── Models ──────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  shortName   String?  @map("short_name")
  code        String   @unique
  parentId    String?  @map("parent_id")
  parent      Organization? @relation("OrgHierarchy", fields: [parentId], references: [id])
  children    Organization[] @relation("OrgHierarchy")
  isActive    Boolean  @default(true) @map("is_active")
  description String?
  attachments Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  taxSubjects  TaxSubject[]
  users        User[]
  customers    Customer[]
  suppliers    Supplier[]
  businessOrders BusinessOrder[]
  costCenters  CostCenter[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  emailVerified  DateTime? @map("email_verified")
  passwordHash   String?  @map("password_hash")
  image          String?
  role           String   @default("user")
  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  outputInvoiceApplications OutputInvoiceApplication[] @relation("CreatedByUser")
  advancePayments          AdvancePayment[] @relation("CreatedByAdvancePayments")
  operationLogs            OperationLog[]

  @@map("users")
}

model TaxSubject {
  id             String       @id @default(cuid())
  name           String
  taxNo          String       @map("tax_no")
  address        String?
  phone          String?
  bankName       String?      @map("bank_name")
  bankAccount    String?      @map("bank_account")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  isDefault      Boolean      @default(false) @map("is_default")
  isActive       Boolean      @default(true) @map("is_active")
  attachments    Json         @default("[]")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  outputInvoiceApplications OutputInvoiceApplication[]
  outputInvoices            OutputInvoice[]

  @@map("tax_subjects")
}

model Customer {
  id             String       @id @default(cuid())
  name           String
  shortName      String?      @map("short_name")
  taxNo          String?      @map("tax_no")
  address        String?
  phone          String?
  bankName       String?      @map("bank_name")
  bankAccount    String?      @map("bank_account")
  contactPerson  String?      @map("contact_person")
  contactPhone   String?      @map("contact_phone")
  contactEmail   String?      @map("contact_email")
  invoiceStrategy InvoiceStrategy @default(NO_INVOICE) @map("invoice_strategy")
  isBlacklisted  Boolean      @default(false) @map("is_blacklisted")
  isActive       Boolean      @default(true) @map("is_active")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  remark         String?
  attachments    Json         @default("[]")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  businessOrders           BusinessOrder[]
  revenueOrders            RevenueOrder[]
  advancePayments          AdvancePayment[]
  outputInvoiceApplications OutputInvoiceApplication[]
  settlements              Settlement[]
  inputInvoices            InputInvoice[]

  @@map("customers")
}

model Supplier {
  id             String       @id @default(cuid())
  name           String
  shortName      String?      @map("short_name")
  taxNo          String?      @map("tax_no")
  address        String?
  phone          String?
  bankName       String?      @map("bank_name")
  bankAccount    String?      @map("bank_account")
  contactPerson  String?      @map("contact_person")
  contactPhone   String?      @map("contact_phone")
  contactEmail   String?      @map("contact_email")
  supplierType   String?      @map("supplier_type")
  isBlacklisted  Boolean      @default(false) @map("is_blacklisted")
  isActive       Boolean      @default(true) @map("is_active")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  remark         String?
  attachments    Json         @default("[]")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  inputInvoices InputInvoice[]

  @@map("suppliers")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  name        String
  category    String?
  taxCode     String?  @map("tax_code")
  taxCodeId   String?  @map("tax_code_id")
  taxCodeRel  TaxCode? @relation(fields: [taxCodeId], references: [id])
  unit        String?
  spec        String?
  isActive    Boolean  @default(true) @map("is_active")
  remark      String?
  attachments Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  outputInvoiceApplicationItems OutputInvoiceApplicationItem[]
  outputInvoiceItems            OutputInvoiceItem[]
  inputInvoiceItems             InputInvoiceItem[]

  @@map("invoice_items")
}

model TaxCode {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  taxRate     Decimal  @default(0) @map("tax_rate")
  category    String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  invoiceItems InvoiceItem[]

  @@map("tax_codes")
}

model BusinessOrder {
  id                    String      @id @default(cuid())
  orderNo               String      @unique @map("order_no")
  orderType             String      @map("order_type")
  title                 String
  customerId            String      @map("customer_id")
  customer              Customer    @relation(fields: [customerId], references: [id])
  organizationId        String      @map("organization_id")
  organization          Organization @relation(fields: [organizationId], references: [id])
  status                OrderStatus @default(DRAFT)
  totalAdvanceAmount    Decimal     @default(0) @map("total_advance_amount")
  collectedAdvanceAmount Decimal    @default(0) @map("collected_advance_amount")
  uncollectedAdvanceAmount Decimal  @default(0) @map("uncollected_advance_amount")
  totalRevenueAmount    Decimal     @default(0) @map("total_revenue_amount")
  invoicedAmount        Decimal     @default(0) @map("invoiced_amount")
  availableAmount       Decimal     @default(0) @map("available_amount")
  currency              Currency    @default(CNY)
  startDate             DateTime?   @map("start_date")
  endDate               DateTime?   @map("end_date")
  remark                String?
  attachments           Json        @default("[]")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  advancePayments  AdvancePayment[]
  revenueOrders    RevenueOrder[]
  inputInvoices    InputInvoice[]
  feeItems         FeeItem[]

  @@map("business_orders")
}

model RevenueOrder {
  id               String        @id @default(cuid())
  orderNo          String        @unique @map("order_no")
  title            String
  businessOrderId  String        @map("business_order_id")
  businessOrder    BusinessOrder @relation(fields: [businessOrderId], references: [id])
  customerId       String        @map("customer_id")
  customer         Customer      @relation(fields: [customerId], references: [id])
  totalRevenueAmount Decimal      @default(0) @map("total_revenue_amount")
  invoicedAmount   Decimal       @default(0) @map("invoiced_amount")
  availableAmount  Decimal       @default(0) @map("available_amount")
  invoiceStatus    String        @default("NOT_INVOICED") @map("invoice_status")
  currency         Currency      @default(CNY)
  startDate        DateTime?     @map("start_date")
  endDate          DateTime?     @map("end_date")
  isActive         Boolean       @default(true) @map("is_active")
  remark           String?
  attachments      Json          @default("[]")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  outputInvoiceApplications OutputInvoiceApplication[]
  settlements               Settlement[]

  @@map("revenue_orders")
}

model CostCenter {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String
  parentId       String?      @map("parent_id")
  parent         CostCenter?  @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children       CostCenter[] @relation("CostCenterHierarchy")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  manager        String?
  isActive       Boolean      @default(true) @map("is_active")
  description    String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  inputInvoices InputInvoice[]

  @@map("cost_centers")
}

model FeeItem {
  id              String        @id @default(cuid())
  feeNo           String        @unique @map("fee_no")
  businessOrderId String        @map("business_order_id")
  businessOrder   BusinessOrder @relation(fields: [businessOrderId], references: [id])
  feeType         FeeType       @map("fee_type")
  description     String?
  quantity        Decimal       @default(1)
  unitPrice       Decimal       @default(0) @map("unit_price")
  amount          Decimal       @default(0)
  currency        Currency      @default(CNY)
  exchangeRate    Decimal?      @default(1) @map("exchange_rate")
  baseAmount      Decimal       @default(0) @map("base_amount")
  occurredDate    DateTime      @map("occurred_date")
  isInvoiced      Boolean       @default(false) @map("is_invoiced")
  remark          String?
  attachments     Json          @default("[]")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("fee_items")
}

model AdvancePayment {
  id                         String                   @id @default(cuid())
  advanceNo                  String                   @unique @map("advance_no")
  customerId                 String                   @map("customer_id")
  customer                   Customer                 @relation(fields: [customerId], references: [id])
  businessOrderId            String                   @map("business_order_id")
  businessOrder              BusinessOrder            @relation(fields: [businessOrderId], references: [id])
  customsDeclarationId       String?                  @map("customs_declaration_id")
  feeType                    FeeType                  @map("fee_type")
  occurredDate               DateTime                 @map("occurred_date")
  currency                   Currency                 @default(CNY)
  originalAmount             Decimal                  @default(0) @map("original_amount")
  exchangeRate               Decimal?                 @default(1) @map("exchange_rate")
  baseCurrencyAmount         Decimal                  @default(0) @map("base_currency_amount")
  payerType                  PayerType                @default(COMPANY) @map("payer_type")
  invoiceStrategy            InvoiceStrategy          @default(NO_INVOICE) @map("invoice_strategy")
  collectionStatus           AdvanceCollectionStatus  @default(PENDING) @map("collection_status")
  writeOffStatus             WriteOffStatus           @default(PENDING) @map("write_off_status")
  status                     AdvanceStatus            @default(DRAFT)
  isInvoiced                 Boolean                  @default(false) @map("is_invoiced")
  isInSettlement             Boolean                  @default(false) @map("is_in_settlement")
  relatedInvoiceId           String?                  @map("related_invoice_id")
  relatedCustomsPaymentBookId String?                 @map("related_customs_payment_book_id")
  collectedAmount            Decimal                  @default(0) @map("collected_amount")
  remark                     String?
  attachments                Json                     @default("[]")
  createdBy                  String?                  @map("created_by")
  creator                    User?                    @relation("CreatedByAdvancePayments", fields: [createdBy], references: [id])
  createdAt                  DateTime                 @default(now()) @map("created_at")
  updatedAt                  DateTime                 @updatedAt @map("updated_at")

  settlementItems SettlementItem[]

  @@map("advance_payments")
}

model Settlement {
  id             String           @id @default(cuid())
  settlementNo   String           @unique @map("settlement_no")
  settlementType SettlementType   @map("settlement_type")
  customerId     String?          @map("customer_id")
  customer       Customer?        @relation(fields: [customerId], references: [id])
  supplierId     String?          @map("supplier_id")
  revenueOrderId String?          @map("revenue_order_id")
  revenueOrder   RevenueOrder?    @relation(fields: [revenueOrderId], references: [id])
  businessOrderId String?         @map("business_order_id")
  title          String
  periodStart    DateTime?        @map("period_start")
  periodEnd      DateTime?        @map("period_end")
  totalAmount    Decimal          @default(0) @map("total_amount")
  invoicedAmount Decimal          @default(0) @map("invoiced_amount")
  receivedAmount Decimal          @default(0) @map("received_amount")
  currency       Currency         @default(CNY)
  status         SettlementStatus @default(DRAFT)
  isAdvanceIncluded Boolean       @default(false) @map("is_advance_included")
  remark         String?
  attachments    Json             @default("[]")
  createdBy      String?          @map("created_by")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  items                      SettlementItem[]
  outputInvoiceApplications  OutputInvoiceApplication[]

  @@map("settlements")
}

model SettlementItem {
  id               String          @id @default(cuid())
  settlementId     String          @map("settlement_id")
  settlement       Settlement      @relation(fields: [settlementId], references: [id])
  feeType          FeeType         @map("fee_type")
  description      String?
  amount           Decimal         @default(0)
  taxRate          Decimal?        @map("tax_rate")
  taxAmount        Decimal         @default(0) @map("tax_amount")
  totalAmount      Decimal         @default(0) @map("total_amount")
  isInvoiced       Boolean         @default(false) @map("is_invoiced")
  advancePaymentId String?         @map("advance_payment_id")
  advancePayment   AdvancePayment? @relation(fields: [advancePaymentId], references: [id])
  feeItemId        String?         @map("fee_item_id")
  remark           String?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@map("settlement_items")
}

model OutputInvoiceApplication {
  id                String      @id @default(cuid())
  applicationNo     String      @unique @map("application_no")
  sourceType        SourceType  @map("source_type")
  sourceId          String?     @map("source_id")
  revenueOrderId    String?     @map("revenue_order_id")
  revenueOrder      RevenueOrder? @relation(fields: [revenueOrderId], references: [id])
  settlementId      String?     @map("settlement_id")
  settlement        Settlement? @relation(fields: [settlementId], references: [id])
  taxSubjectId      String      @map("tax_subject_id")
  taxSubject        TaxSubject  @relation(fields: [taxSubjectId], references: [id])
  sellerTaxNo       String?     @map("seller_tax_no")
  customerId        String      @map("customer_id")
  customer          Customer    @relation(fields: [customerId], references: [id])
  buyerName         String      @map("buyer_name")
  buyerTaxNo        String?     @map("buyer_tax_no")
  buyerAddress      String?     @map("buyer_address")
  buyerPhone        String?     @map("buyer_phone")
  buyerBankName     String?     @map("buyer_bank_name")
  buyerBankAccount  String?     @map("buyer_bank_account")
  invoiceCategory   InvoiceCategory @map("invoice_category")
  amountWithoutTax  Decimal     @default(0) @map("amount_without_tax")
  taxAmount         Decimal     @default(0) @map("tax_amount")
  amountWithTax     Decimal     @default(0) @map("amount_with_tax")
  currency          Currency    @default(CNY)
  exchangeRate      Decimal?    @default(1) @map("exchange_rate")
  status            AppStatus   @default(DRAFT)
  deliveryMethod    DeliveryMethod? @map("delivery_method")
  recipientEmail    String?     @map("recipient_email")
  remark            String?
  invoiceNo         String?     @map("invoice_no")
  taxSerialNo       String?     @map("tax_serial_no")
  attachments       Json        @default("[]")
  createdBy         String?     @map("created_by")
  creator           User?       @relation("CreatedByUser", fields: [createdBy], references: [id])
  approvedBy        String?     @map("approved_by")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  items              OutputInvoiceApplicationItem[]
  outputInvoice      OutputInvoice?

  @@map("output_invoice_applications")
}

model OutputInvoiceApplicationItem {
  id                        String                     @id @default(cuid())
  applicationId             String                     @map("application_id")
  application               OutputInvoiceApplication   @relation(fields: [applicationId], references: [id])
  itemName                  String                     @map("item_name")
  taxClassificationCode     String?                    @map("tax_classification_code")
  invoiceItemId             String?                    @map("invoice_item_id")
  invoiceItem               InvoiceItem?               @relation(fields: [invoiceItemId], references: [id])
  spec                      String?
  unit                      String?
  quantity                  Decimal                    @default(1)
  unitPrice                 Decimal                    @default(0) @map("unit_price")
  amount                    Decimal                    @default(0)
  taxRate                   Decimal                    @default(0) @map("tax_rate")
  taxAmount                 Decimal                    @default(0) @map("tax_amount")
  totalAmount               Decimal                    @default(0) @map("total_amount")
  feeType                   FeeType?                   @map("fee_type")
  feeItemId                 String?                    @map("fee_item_id")
  advancePaymentId          String?                    @map("advance_payment_id")
  sortOrder                 Int                        @default(0) @map("sort_order")
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")

  @@map("output_invoice_application_items")
}

model OutputInvoice {
  id                String                     @id @default(cuid())
  invoiceNo         String                     @unique @map("invoice_no")
  invoiceCode       String?                    @map("invoice_code")
  invoiceCategory   InvoiceCategory            @map("invoice_category")
  direction         InvoiceDirection           @default(OUTPUT)
  blueRedFlag       BlueRedFlag                @default(BLUE) @map("blue_red_flag")
  applicationId     String?                    @unique @map("application_id")
  application       OutputInvoiceApplication?  @relation(fields: [applicationId], references: [id])
  taxSubjectId      String                     @map("tax_subject_id")
  taxSubject        TaxSubject                 @relation(fields: [taxSubjectId], references: [id])
  sellerName        String                     @map("seller_name")
  sellerTaxNo       String                     @map("seller_tax_no")
  buyerName         String                     @map("buyer_name")
  buyerTaxNo        String?                    @map("buyer_tax_no")
  buyerAddress      String?                    @map("buyer_address")
  buyerPhone        String?                    @map("buyer_phone")
  buyerBankName     String?                    @map("buyer_bank_name")
  buyerBankAccount  String?                    @map("buyer_bank_account")
  issueDate         DateTime?                  @map("issue_date")
  amountWithoutTax  Decimal                    @default(0) @map("amount_without_tax")
  taxAmount         Decimal                    @default(0) @map("tax_amount")
  amountWithTax     Decimal                    @default(0) @map("amount_with_tax")
  currency          Currency                   @default(CNY)
  remark            String?
  deliveryStatus    DeliveryStatus             @default(PENDING) @map("delivery_status")
  verifyStatus      VerifyStatus               @default(PENDING) @map("verify_status")
  redFlushStatus    RedFlushStatus?            @map("red_flush_status")
  voidStatus        VoidStatus?                @map("void_status")
  accountStatus     AccountStatus              @default(UNACCOUNTED) @map("account_status")
  archiveStatus     ArchiveStatus              @default(UNARCHIVED) @map("archive_status")
  attachments       Json                       @default("[]")
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedAt         DateTime                   @updatedAt @map("updated_at")

  items              OutputInvoiceItem[]
  redFlushApplications RedFlushApplication[]
  voidApplications   VoidApplication[]
  deliveryRecords    InvoiceDeliveryRecord[]
  verifyRecords      InvoiceVerifyRecord[]
  invoiceFiles       InvoiceFile[]

  @@map("output_invoices")
}

model OutputInvoiceItem {
  id                    String       @id @default(cuid())
  invoiceId             String       @map("invoice_id")
  invoice               OutputInvoice @relation(fields: [invoiceId], references: [id])
  itemName              String       @map("item_name")
  taxClassificationCode String?      @map("tax_classification_code")
  invoiceItemId         String?      @map("invoice_item_id")
  invoiceItem           InvoiceItem? @relation(fields: [invoiceItemId], references: [id])
  spec                  String?
  unit                  String?
  quantity              Decimal      @default(1)
  unitPrice             Decimal      @default(0) @map("unit_price")
  amount                Decimal      @default(0)
  taxRate               Decimal      @default(0) @map("tax_rate")
  taxAmount             Decimal      @default(0) @map("tax_amount")
  totalAmount           Decimal      @default(0) @map("total_amount")
  feeType               FeeType?     @map("fee_type")
  sortOrder             Int          @default(0) @map("sort_order")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  @@map("output_invoice_items")
}

model InputInvoice {
  id                   String            @id @default(cuid())
  invoiceNo            String            @map("invoice_no")
  invoiceCode          String?           @map("invoice_code")
  invoiceCategory      InvoiceCategory   @map("invoice_category")
  direction            InvoiceDirection  @default(INPUT)
  blueRedFlag          BlueRedFlag       @default(BLUE) @map("blue_red_flag")
  originalInvoiceId    String?           @map("original_invoice_id")
  sellerName           String            @map("seller_name")
  sellerTaxNo          String            @map("seller_tax_no")
  buyerName            String            @map("buyer_name")
  buyerTaxNo           String            @map("buyer_tax_no")
  supplierId           String?           @map("supplier_id")
  supplier             Supplier?         @relation(fields: [supplierId], references: [id])
  customerId           String?           @map("customer_id")
  customer             Customer?         @relation(fields: [customerId], references: [id])
  businessOrderId      String?           @map("business_order_id")
  businessOrder        BusinessOrder?    @relation(fields: [businessOrderId], references: [id])
  costCenterId         String?           @map("cost_center_id")
  costCenter           CostCenter?       @relation(fields: [costCenterId], references: [id])
  issueDate            DateTime?         @map("issue_date")
  amountWithoutTax     Decimal           @default(0) @map("amount_without_tax")
  taxAmount            Decimal           @default(0) @map("tax_amount")
  amountWithTax        Decimal           @default(0) @map("amount_with_tax")
  taxRate              Decimal?          @map("tax_rate")
  currency             Currency          @default(CNY)
  status               InputInvoiceStatus @default(PENDING_PARSE)
  verifyStatus         VerifyStatus      @default(PENDING) @map("verify_status")
  deductStatus         DeductStatus      @default(PENDING) @map("deduct_status")
  accountStatus        AccountStatus     @default(UNACCOUNTED) @map("account_status")
  archiveStatus        ArchiveStatus     @default(UNARCHIVED) @map("archive_status")
  isAdvanceCost        Boolean           @default(false) @map("is_advance_cost")
  costType             FeeType?          @map("cost_type")
  costAllocationRatio  Decimal?          @default(100) @map("cost_allocation_ratio")
  remark               String?
  attachments          Json              @default("[]")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  items         InputInvoiceItem[]
  verifyRecords InvoiceVerifyRecord[]
  invoiceFiles  InvoiceFile[]

  @@map("input_invoices")
}

model InputInvoiceItem {
  id                    String      @id @default(cuid())
  invoiceId             String      @map("invoice_id")
  invoice               InputInvoice @relation(fields: [invoiceId], references: [id])
  itemName              String      @map("item_name")
  taxClassificationCode String?     @map("tax_classification_code")
  invoiceItemId         String?     @map("invoice_item_id")
  invoiceItem           InvoiceItem? @relation(fields: [invoiceItemId], references: [id])
  spec                  String?
  unit                  String?
  quantity              Decimal     @default(1)
  unitPrice             Decimal     @default(0) @map("unit_price")
  amount                Decimal     @default(0)
  taxRate               Decimal     @default(0) @map("tax_rate")
  taxAmount             Decimal     @default(0) @map("tax_amount")
  totalAmount           Decimal     @default(0) @map("total_amount")
  sortOrder             Int         @default(0) @map("sort_order")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

